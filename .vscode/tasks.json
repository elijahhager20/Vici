{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe",
            "command": "insert path to g++.exe",
            "args": [
                "-static",
                "-fdiagnostics-color=always",
                "main.cpp",
                "init.cpp",
                "-o",
                "${fileDirname}\\vici.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task updated for static linking"
        }
    ]
}
